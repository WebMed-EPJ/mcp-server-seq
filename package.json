{
  "name": "mcp-seq",
  "version": "1.0.1",
  "description": "MCP Server for Seq's API endpoints",
  "type": "module",
  "main": "build/seq-server.js",
  "bin": {
    "mcp-seq": "build/seq-server.js"
  },
  "scripts": {
    "build": "tsc && npm run bundle && shx chmod +x build/*.js",
    "bundle": "esbuild src/seq-server.ts --bundle --platform=node --format=esm --target=node20 --outfile=build/seq-server.js --banner:js=\"import{createRequire as __cr}from'module';const require=__cr(import.meta.url);\"",
    "prepare": "npm run build",
    "start": "node build/seq-server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test-script": "node build/seq-test.js",
    "dev": "tsc -w"
  },
  "keywords": [
    "mcp",
    "seq",
    "logging",
    "claude"
  ],
  "author": "Ahmad Atighechi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmad2x4/mcp-server-seq.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "dotenv": "^16.3.1",
    "openredaction": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "cross-env": "^7.0.3",
    "esbuild": "0.24.2",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
