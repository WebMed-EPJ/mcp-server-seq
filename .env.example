# WebMed Seq MCP connector — environment configuration.
# Copy to .env for local development. NEVER commit real values.

# ── Seq upstream (used by BOTH the stdio and remote entry points) ────────────
# Base URL of the Seq server. The stdio bundle defaults to http://localhost:8080
# when unset; the remote server has no default target so set it explicitly.
SEQ_BASE_URL=https://seq.internal.webmed.no

# Seq API key. Most Seq instances reject unauthenticated API calls. The remote
# server REFUSES TO START without it (fail-closed); the stdio entry only warns.
# This key is GLOBAL and server-side — it must only ever live on the hosted
# server (or an admin's machine), never on end-user machines.
SEQ_API_KEY=

# ── PII redaction (GDPR / Personvern) ────────────────────────────────────────
# All Seq log data is redacted of Norwegian personal data (fødselsnummer, names,
# phones, emails) before leaving the server. Enabled by default; set to false
# ONLY for local debugging against an instance with no real personal data.
#SEQ_REDACTION_ENABLED=true

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error | silent (default info). Logs go to
# stderr. The logger never writes the API key, response bodies, or PII —
# query-string VALUES (incl. the OAuth /callback code) are masked.
#SEQ_LOG_LEVEL=info

# ── Remote server (the hosted HTTP MCP server, src/remote.ts / Docker) ───────
# Users sign in with Microsoft Entra (OAuth 2.1) — the same model as the WebMed
# Lime/m365 connectors. The Entra leg purely AUTHENTICATES the caller; the Seq
# API key above stays global and server-side. All four vars below are REQUIRED
# for the remote server (it refuses to start without them, fail-closed).

# Public https origin claude.ai reaches. The OAuth metadata and the Entra
# redirect URI (<origin>/callback) are derived from it. Must be absolute https.
REMOTE_PUBLIC_URL=https://seq-mcp.webmed.no

# Microsoft Entra app registration (WebMed tenant). Register a CONFIDENTIAL
# client with a "Web" platform redirect URI of <REMOTE_PUBLIC_URL>/callback and
# a client secret. Sign-in is restricted to this single tenant.
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=

# Sign-in scopes. Default: OIDC only ("openid profile email offline_access") —
# the connector never calls Microsoft Graph, so it requests no Graph permissions.
# Space-separated; override only if your tenant needs different login scopes.
#ENTRA_SCOPES=openid profile email offline_access

# Port the remote server listens on (plain HTTP — terminate TLS in front).
#PORT=8790

# Reverse-proxy hops in front of the process (TLS ingress / load balancer).
# Default 1. NEVER set higher than the real hop count (X-Forwarded-For spoofing).
#TRUST_PROXY_HOPS=1

# Max JSON body size for /mcp requests. Default 1mb.
#MAX_JSON_BODY=1mb
